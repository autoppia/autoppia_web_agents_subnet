# ============================================================================
# VALIDATOR ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and fill in your actual values.
# DO NOT commit your .env file to version control!
# ============================================================================

# ============================================================================
# VALIDATOR IDENTITY [REQUIRED]
# ============================================================================
VALIDATOR_NAME="Your Validator Name"
VALIDATOR_IMAGE="https://example.com/your-validator-image.png"

# ============================================================================
# IWA CONFIGURATION [REQUIRED for task generation]
# ============================================================================
# The validator uses IWA to generate tasks. These variables are needed by IWA.

# Select which LLM provider to use for task generation.
LLM_PROVIDER="openai"

# Gateway providers default to openai,chutes, so BOTH keys are required.
OPENAI_API_KEY="sk-proj-..."
CHUTES_API_KEY="cpk_..."

# OpenAI Configuration (if LLM_PROVIDER="openai")
OPENAI_MODEL="gpt-4o-mini"
OPENAI_MAX_TOKENS="10000"
OPENAI_TEMPERATURE="0.7"

# Chutes Configuration (if LLM_PROVIDER="chutes")
# CHUTES_BASE_URL="https://your-username-your-chute.chutes.ai/v1"
# CHUTES_MODEL="meta-llama/Llama-3.1-8B-Instruct"
# CHUTES_MAX_TOKENS=2048
# CHUTES_TEMPERATURE=0.7
# CHUTES_USE_BEARER=False

# ============================================================================
# STORAGE BACKENDS (Hippius SN 75 integration)
# ============================================================================
# IPFS backend: "standard" (default) or "hippius"
# STORAGE_IPFS_BACKEND="standard"

# Standard IPFS settings (default backend)
# IPFS_API_URL="http://ipfs.metahash73.com:5001/api/v0"
# IPFS_GATEWAYS="https://ipfs.io/ipfs,https://cloudflare-ipfs.com/ipfs"

# Hippius IPFS settings (when STORAGE_IPFS_BACKEND="hippius")
# HIPPIUS_IPFS_API_URL="http://localhost:5001"
# HIPPIUS_KEY="your-hippius-key"

# S3 backend: "aws" (default) or "hippius"
# STORAGE_S3_BACKEND="aws"

# AWS S3 settings (when STORAGE_S3_BACKEND="aws")
# AWS_ACCESS_KEY_ID="your-aws-access-key"
# AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
# AWS_S3_REGION="us-east-1"
# AWS_S3_ENDPOINT_URL=""

# Hippius S3 settings (when STORAGE_S3_BACKEND="hippius")
# HIPPIUS_S3_ACCESS_KEY="hip_your_access_key"
# HIPPIUS_S3_SECRET_KEY="your-secret-key"
# HIPPIUS_S3_ENDPOINT="s3.hippius.com"
# HIPPIUS_S3_REGION="decentralized"

# S3 metadata upload (stores evaluation data for public datasets)
# S3_METADATA_UPLOAD_ENABLED=false
# S3_METADATA_BUCKET="autoppia-evaluation-metadata"

# ============================================================================
# EMAIL REPORTING (Optional)
# ============================================================================
# REPORT_MONITOR_SMTP_HOST="smtp.your-provider.com"
# REPORT_MONITOR_SMTP_PORT=465
# REPORT_MONITOR_SMTP_USERNAME="your-email@domain.com"
# REPORT_MONITOR_SMTP_PASSWORD="your-password"
# REPORT_MONITOR_SMTP_SSL=true
# REPORT_MONITOR_EMAIL_FROM="validator@domain.com"
# REPORT_MONITOR_EMAIL_TO="reports@domain.com"
# REPORT_MONITOR_RUN_CODEX=false
